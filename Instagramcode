import numpy as np


def create_views_array(views_data: list) -> np.ndarray:
    """
    Creates a NumPy array from daily Instagram Reel views.
    """
    return np.array(views_data, dtype=np.int64)


def validate_views_array(views_array: np.ndarray) -> bool:
    """
    Checks whether the views array contains valid non-negative numeric values.
    """

    if not isinstance(views_array, np.ndarray):
        return False

    if views_array.size == 0:
        return False

    if not np.issubdtype(views_array.dtype, np.number):
        return False

    if np.any(views_array < 0):
        return False

    return True


def compute_view_metrics(views_array: np.ndarray) -> tuple:
    """
    Returns total views, average views, and maximum views.
    """

    total_views = int(np.sum(views_array))
    average_views = round(float(np.mean(views_array)), 2)
    maximum_views = int(np.max(views_array))

    return (total_views, average_views, maximum_views)


def categorize_trend_levels(views_array: np.ndarray) -> np.ndarray:
    """
    Labels each day's reel views as:
    Low Trend, Moderate Trend, Viral Trend
    """

    return np.where(
        views_array < 3000,
        "Low Trend",
        np.where(
            views_array < 5000,
            "Moderate Trend",
            "Viral Trend"
        )
    )


def longest_growth_streak(views_array: np.ndarray) -> int:
    """
    Finds the longest sequence of consecutive days
    where views increased compared to the previous day.

    Returns streak length in number of days.
    """

    n = len(views_array)

    if n == 0:
        return 0

    if n == 1:
        return 1

    longest = 1
    current = 1

    for i in range(1, n):
        if views_array[i] > views_array[i - 1]:
            current += 1
        else:
            longest = max(longest, current)
            current = 1

    longest = max(longest, current)

    return longest


def format_view_counts(views_array: np.ndarray) -> np.ndarray:
    """
    Formats view counts with comma separators.
    """

    return np.array(
        [f"{int(value):,}" for value in views_array]
    )
